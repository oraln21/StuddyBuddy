extends layout

block content
  .session-detail
    h1= session.topic
    p 📍 #{session.location || 'Location TBD'}
    p 📅 #{new Date(session.scheduled_time).toLocaleString()}
    p 👤 Organised by
      a(href="/users/" + session.creator_id)  #{session.first_name} #{session.last_name}
    p 👥 Max Participants: #{session.max_participants || 'Unlimited'}

  section
    h2 Participants
    if participants.length
      ul
        each p in participants
          li
            a(href="/users/" + p.user_id)= p.first_name + ' ' + p.last_name
            span  – #{p.status}
    else
      p No participants yet. Be the first to join!

  a.btn(href="/sessions") &larr; Back to Sessions
