extends layout

block content
  h1 Study Sessions
  .filter-strip
    a(href="/sessions") All
    a(href="/tags") By Topic

  .grid
    each session in sessions
      .card
        .card-header
          h2= session.topic
        .card-body
          p 📍 #{session.location || 'Location TBD'}
          p 📅 #{new Date(session.scheduled_time).toLocaleString('en-GB')}
          p 👤 #{session.first_name} #{session.last_name}
          p 👥 #{session.joined}/#{session.max_participants || '∞'}
        .card-footer
          a.btn(href="/sessions/" + session.session_id) View →
