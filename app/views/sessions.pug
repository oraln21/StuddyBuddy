extends layout

block content
  h1 Study Sessions
  p Join or browse available study sessions.

  .filter-bar
    a(href="/sessions") All Topics
    a(href="/tags") Browse by Topic

  .session-list
    each session in sessions
      .session-card
        h2= session.topic
        p 📍 Location: #{session.location || 'TBD'}
        p 📅 #{new Date(session.scheduled_time).toLocaleString()}
        p 👤 Organised by #{session.first_name} #{session.last_name}
        p 👥 #{session.participant_count} / #{session.max_participants || '∞'} participants
        a(href="/sessions/" + session.session_id) View Details
